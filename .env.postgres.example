ZYTE_API_KEY=
ZYTE_API_URL=https://api.zyte.com/v1/extract
SCRAPING_USE_ZYTE=false
SCRAPING_FIXTURE_MODE=true
SCRAPING_COUNTRY=CA
DATABASE_URL=postgresql+psycopg://car_dealer:car_dealer_password@localhost:55433/car_dealer
OBJECT_STORE_ROOT=var/object-store
SOURCE_SNAPSHOT_RETENTION_DAYS=90
SAVED_SEARCH_REFRESH_ENABLED=false
SAVED_SEARCH_REFRESH_POLL_SECONDS=3600
SAVED_SEARCH_REFRESH_BATCH_LIMIT=25
SAVED_SEARCH_REFRESH_DEFAULT_SCHEDULE=daily
ALERT_EMAIL_DRY_RUN=true
ALERT_EMAIL_FROM=alerts@car-dealer.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3.5-flash
AI_EXTRACTION_ENABLED=true
GEMINI_TEXT_ANALYSIS_ENABLED=false
GEMINI_IMAGE_ANALYSIS_ENABLED=false
IMAGE_FETCH_TIMEOUT_SECONDS=8
IMAGE_FETCH_MAX_BYTES=5000000
